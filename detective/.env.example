# ══════════════════════════════════════════════════════════════
#  Data Detective — environment variables
# ══════════════════════════════════════════════════════════════

# ── Auth ───────────────────────────────────────────────────────
# Not needed — Detective uses Claude Code's built-in auth (OAuth).
# No separate ANTHROPIC_API_KEY required.

# ── Detective tuning (optional) ──────────────────────────────
# DETECTIVE_MODEL=claude-sonnet-4-20250514
# DETECTIVE_MAX_ITER=15

# ── BigQuery (optional — needed for BQ investigations) ───────
# BQ_PROJECT=my-gcp-project
# BQ_CREDENTIALS_PATH=/path/to/service-account.json

# ── Snowflake (optional — needed for SF investigations) ──────
# Use SNOWFLAKE_* prefix (auto-mapped to SF_* by walter)
# SNOWFLAKE_ACCOUNT=myaccount.us-central1.gcp
# SNOWFLAKE_USER=myuser
# SNOWFLAKE_PASSWORD=mypassword
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_DATABASE=MY_DB
# SNOWFLAKE_ROLE=ANALYST
