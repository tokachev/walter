# ══════════════════════════════════════════════════════════════
#  Data Detective — environment variables
# ══════════════════════════════════════════════════════════════

# ── Anthropic auth (one of these is required) ────────────────
# OAuth token — same as used for Claude Code (preferred)
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat...
# Or a direct API key (fallback)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Detective tuning (optional) ──────────────────────────────
# DETECTIVE_MODEL=claude-sonnet-4-20250514
# DETECTIVE_MAX_ITER=15
# DETECTIVE_MAX_TOKENS=8000

# ── BigQuery (optional — needed for BQ investigations) ───────
# BQ_PROJECT=my-gcp-project
# BQ_CREDENTIALS_PATH=/path/to/service-account.json

# ── Snowflake (optional — needed for SF investigations) ──────
# SF_ACCOUNT=myaccount.snowflakecomputing.com
# SF_USER=myuser
# SF_PASSWORD=mypassword
# SF_PRIVATE_KEY_PATH=/path/to/rsa_key.pem
# SF_WAREHOUSE=COMPUTE_WH
# SF_DATABASE=MY_DB
# SF_SCHEMA=PUBLIC
# SF_ROLE=ANALYST
