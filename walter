#!/bin/bash
# ══════════════════════════════════════════════════════════════
#  walter — Docker launcher for Claude Code with
#  network isolation and credential-guard
# ══════════════════════════════════════════════════════════════

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Subcommands ──────────────────────────────────────────────
if [ "${1:-}" = "dashboard" ]; then
  shift
  DASH_PORT="${WALTER_DASHBOARD_PORT:-19433}"
  SESSIONS_DIR="${HOME}/.walter/sessions"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port|-p) DASH_PORT="$2"; shift 2 ;;
      --sessions-dir) SESSIONS_DIR="$2"; shift 2 ;;
      -h|--help) echo "Usage: walter dashboard [--port PORT] [--sessions-dir DIR]"; exit 0 ;;
      *) echo "Unknown dashboard option: $1"; exit 1 ;;
    esac
  done
  mkdir -p "$SESSIONS_DIR"
  exec node "$SCRIPT_DIR/dashboard/server.js" --sessions-dir "$SESSIONS_DIR" --port "$DASH_PORT"
fi

IMAGE_NAME="walter"
IMAGE_TAG="latest"

PROJECT_DIR=""
EXTRA_DOMAINS=""
SNOWFLAKE_KEY=""
BQ_CREDENTIALS=""
BQ_MCP_CONFIG=""
GCLOUD_ADC=false
BUILD=false
PLAN_FILE=""
PLAN_MAX_ITERATIONS=""
PLAN_RETRY_COUNT=""
REVIEW=false
REVIEW_ONLY=false

usage() {
  cat << 'EOF'
Usage: walter [options] [claude args...]
       walter dashboard [--port PORT]

Launches Claude Code inside a Docker container with:
  - Network firewall (only api.anthropic.com allowed)
  - Credential-guard plugin (blocks secrets in files)
  - Session logging to ~/.walter/sessions/ (visible via 'walter dashboard')

Options:
  -d, --dir <path>         Project directory (default: current dir)
  -a, --allow <domains>    Extra domains to allow (comma-separated)
  --snowflake-key <path>   Snowflake private key PEM file
  --bq-credentials <path>  BigQuery service account JSON key file (override)
  --bq-mcp-config <path>   BigQuery MCP config JSON file
  --gcloud                 Mount host gcloud ADC for BigQuery (no SA key needed)
  --plan <file>            Execute a markdown plan file (task-by-task)
  --plan-max-iter <n>      Max iterations for plan execution (default: 600)
  --plan-retries <n>       Retry count per task (default: 2)
  --review                 Run plan then review (code review after execution)
  --review-only            Skip plan execution; run review only
  --build                  Rebuild Docker image
  -h, --help               Show this help

Subcommands:
  dashboard                Start the web dashboard (monitors all sessions)
    --port PORT            Dashboard port (default: 19433)
    --sessions-dir DIR     Sessions directory (default: ~/.walter/sessions)

Auth: CLAUDE_CODE_OAUTH_TOKEN from walter .env

Project credentials from <project>/.env:
  SNOWFLAKE_*              — Snowflake read-only MCP + auto-mapped to SF_* for Detective
  BQ_PROJECT, BQ_CREDENTIALS_PATH — BigQuery (Data Detective)
  SF_*                     — Snowflake (Data Detective, explicit override)
  OPENAI_API_KEY           — Codex peer review (/peer-review command)

Examples:
  walter -d ./my-project                    # all from .env
  walter -d ./my-project "Add auth module"  # with prompt
  walter -d ./my-project -p "Fix bug #42"   # pass -p flag
  walter --allow "pypi.org" -d ./project
  walter --plan .claude/plans/my-plan.md -d ./project  # execute plan
  walter dashboard                                     # open web dashboard
  walter dashboard --port 8080                         # custom port
EOF
  exit 1
}

CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -d|--dir)       PROJECT_DIR="$2"; shift 2 ;;
    -a|--allow)     EXTRA_DOMAINS="$2"; shift 2 ;;
    --snowflake-key) SNOWFLAKE_KEY="$2"; shift 2 ;;
    --bq-credentials) BQ_CREDENTIALS="$2"; shift 2 ;;
    --bq-mcp-config) BQ_MCP_CONFIG="$2"; shift 2 ;;
    --gcloud)       GCLOUD_ADC=true; shift ;;
    -p|--plan)      PLAN_FILE="$2"; shift 2 ;;
    --plan-max-iter) PLAN_MAX_ITERATIONS="$2"; shift 2 ;;
    --plan-retries) PLAN_RETRY_COUNT="$2"; shift 2 ;;
    --review)       REVIEW=true; shift ;;
    --review-only)  REVIEW_ONLY=true; shift ;;
    --build)        BUILD=true; shift ;;
    -h|--help)      usage ;;
    *)              CLAUDE_ARGS+=("$1"); shift ;;
  esac
done

PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"
PROJECT_DIR=$(cd "$PROJECT_DIR" && pwd)

# ── Flag validation ────────────────────────────────────────
if [ "$REVIEW" = true ] && [ -z "$PLAN_FILE" ]; then
  echo "ERROR: --review requires --plan (use --review-only for standalone review)"
  exit 1
fi

# ── Plan file validation ────────────────────────────────────
if [ -n "$PLAN_FILE" ]; then
  # Resolve relative to project dir
  if [[ "$PLAN_FILE" != /* ]]; then
    PLAN_FILE="$PROJECT_DIR/$PLAN_FILE"
  fi
  if [ ! -f "$PLAN_FILE" ]; then
    echo "ERROR: Plan file not found: $PLAN_FILE"
    exit 1
  fi
  # Convert to path relative to project dir for container mapping
  PLAN_FILE_REL="${PLAN_FILE#"$PROJECT_DIR/"}"
  PLAN_FILE_CONTAINER="/workspace/$PLAN_FILE_REL"
fi

# ── Build image if needed ────────────────────────────────────
if [ "$BUILD" = true ] || ! docker image inspect "$IMAGE_NAME:$IMAGE_TAG" &>/dev/null; then
  echo "Building Docker image..."
  docker build -t "$IMAGE_NAME:$IMAGE_TAG" "$SCRIPT_DIR"
  echo ""
fi

# ── Mounts ───────────────────────────────────────────────────
MOUNTS=(
  -v "$PROJECT_DIR:/workspace"
)

# ── Mount host's Claude agents + settings ─────────────────────
CLAUDE_HOME="${CLAUDE_HOME:-$HOME/.claude}"
HOST_CLAUDE_AGENTS_MOUNTED=false
HOST_CLAUDE_COMMANDS_MOUNTED=false

if [ -d "$CLAUDE_HOME/agents" ]; then
  MOUNTS+=(-v "$CLAUDE_HOME/agents:/opt/claude-home/.claude/agents:ro")
  HOST_CLAUDE_AGENTS_MOUNTED=true
fi

if [ -f "$CLAUDE_HOME/settings.json" ]; then
  MOUNTS+=(-v "$CLAUDE_HOME/settings.json:/tmp/host-settings.json:ro")
fi

if [ -f "$CLAUDE_HOME/CLAUDE.md" ]; then
  MOUNTS+=(-v "$CLAUDE_HOME/CLAUDE.md:/opt/claude-home/.claude/CLAUDE.md:ro")
fi

if [ -d "$CLAUDE_HOME/rules" ]; then
  MOUNTS+=(-v "$CLAUDE_HOME/rules:/opt/claude-home/.claude/rules:ro")
fi

if [ -d "$CLAUDE_HOME/commands" ]; then
  MOUNTS+=(-v "$CLAUDE_HOME/commands:/opt/claude-home/.claude/commands:ro")
  HOST_CLAUDE_COMMANDS_MOUNTED=true
fi

if [ -d "$CLAUDE_HOME/skills" ]; then
  MOUNTS+=(-v "$CLAUDE_HOME/skills:/opt/claude-home/.claude/skills:ro")
fi

# Persist session data for Insights: mount project-specific dir so each
# project's sessions, memory, and insights stay isolated on the host.
# Inside the container the workdir is always /workspace, so Claude Code
# writes to ~/.claude/projects/-workspace/. We map that to a per-project
# host dir: ~/.claude/projects/-workspace-<project_name>/
PROJECT_NAME="$(basename "$PROJECT_DIR")"
PROJECTS_HOST_DIR="$CLAUDE_HOME/projects/-workspace-${PROJECT_NAME}"
mkdir -p "$PROJECTS_HOST_DIR"

MOUNTS+=(-v "$PROJECTS_HOST_DIR:/opt/claude-home/.claude/projects/-workspace")

# Share auto-memory with native Claude Code CLI sessions on the host.
# Native Claude Code normalizes the project path to an ID by replacing every
# non-alphanumeric character with "-". We do the same here so Walter and the
# host CLI write into the same memory directory. The dir is then bind-mounted
# into /opt/claude-home/.claude/projects/-workspace/memory — the native path
# Claude Code uses inside the container (since WORKDIR=/workspace).
HOST_PROJECT_ID=$(printf '%s' "$PROJECT_DIR" | sed 's|[^a-zA-Z0-9]|-|g')
HOST_MEMORY_DIR="$CLAUDE_HOME/projects/${HOST_PROJECT_ID}/memory"
mkdir -p "$HOST_MEMORY_DIR"
MOUNTS+=(-v "$HOST_MEMORY_DIR:/opt/claude-home/.claude/projects/-workspace/memory")

# ── Safe .env parser ─────────────────────────────────────────
# Parses KEY=VALUE pairs without shell execution (no source/eval).
# Handles: empty lines, comments, export prefix, single/double quotes,
# inline comments on unquoted values. Malicious payloads ($(...), `...`)
# are kept as literal strings and never executed.
safe_load_env() {
  local env_file="$1"
  [ -f "$env_file" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    # Skip empty lines and comment lines
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    # Strip leading whitespace and optional 'export ' prefix
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line#export }"
    # Must match KEY=... (KEY: alphanumeric + underscore, starting with letter/underscore)
    [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*) ]] || continue
    local key="${BASH_REMATCH[1]}"
    local val="${BASH_REMATCH[2]}"
    # Double-quoted value: strip quotes, no inline-comment stripping
    if [[ "$val" =~ ^\"(.*) ]]; then
      val="${val#\"}"
      val="${val%\"}"
    # Single-quoted value: strip quotes, no inline-comment stripping
    elif [[ "$val" =~ ^\'(.*) ]]; then
      val="${val#\'}"
      val="${val%\'}"
    else
      # Unquoted: strip inline comment (space + # + anything)
      val="${val%% #*}"
      # Trim trailing whitespace
      val="${val%"${val##*[![:space:]]}"}"
    fi
    export "$key=$val"
  done < "$env_file"
}

# ── Auth (from walter .env) ───────────────────────────────────
ENV_VARS=(
  # Disable telemetry/analytics (segment.io, growthbook.io, datadoghq.com)
  # These services are blocked by the firewall; without this flag Claude Code
  # attempts connections that hang until TCP timeout, adding minutes of latency.
  -e "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1"
  # Default to Opus
  -e "ANTHROPIC_MODEL=claude-opus-4-6[1m]"
  # 24-bit color support inside container
  -e "COLORTERM=${COLORTERM:-truecolor}"
)

[ "$HOST_CLAUDE_AGENTS_MOUNTED" = true ] && ENV_VARS+=(-e "WALTER_HOST_AGENTS_MOUNTED=1")
[ "$HOST_CLAUDE_COMMANDS_MOUNTED" = true ] && ENV_VARS+=(-e "WALTER_HOST_COMMANDS_MOUNTED=1")

# Pass host project path so container can map auto-memory to the correct project ID
ENV_VARS+=(-e "WALTER_HOST_PROJECT_DIR=$PROJECT_DIR")

if [ -f "$SCRIPT_DIR/.env" ]; then
  set -a
  source "$SCRIPT_DIR/.env"
  set +a
fi

if [ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
  ENV_VARS+=(-e "CLAUDE_CODE_OAUTH_TOKEN=$CLAUDE_CODE_OAUTH_TOKEN")
  AUTH_METHOD="OAuth token ($SCRIPT_DIR/.env)"
else
  AUTH_METHOD="No token — add CLAUDE_CODE_OAUTH_TOKEN to $SCRIPT_DIR/.env"
fi

# ── Project .env (detective, BQ, SF credentials) ─────────────
safe_load_env "$PROJECT_DIR/.env"

# ── OpenAI / Codex (peer review) ──────────────────────────────
CODEX_ENABLED=false
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"

if [ -f "$CODEX_HOME/auth.json" ]; then
  MOUNTS+=(-v "$CODEX_HOME/auth.json:/opt/claude-home/.codex/auth.json:ro")
  CODEX_ENABLED=true
fi

if [ -n "$OPENAI_API_KEY" ]; then
  ENV_VARS+=(-e "OPENAI_API_KEY=$OPENAI_API_KEY")
  CODEX_ENABLED=true
fi

if [ "$CODEX_ENABLED" = true ]; then
  CODEX_DOMAINS="api.openai.com,chatgpt.com"
  if [ -n "$EXTRA_DOMAINS" ]; then
    EXTRA_DOMAINS="$EXTRA_DOMAINS,$CODEX_DOMAINS"
  else
    EXTRA_DOMAINS="$CODEX_DOMAINS"
  fi
fi

# ── gcloud ADC (host credentials for BigQuery) ───────────────
if [ "$GCLOUD_ADC" = true ]; then
  ADC_FILE="$HOME/.config/gcloud/application_default_credentials.json"
  if [ ! -f "$ADC_FILE" ]; then
    echo "ERROR: gcloud ADC not found at $ADC_FILE"
    echo "Run:   gcloud auth application-default login"
    exit 1
  fi
  MOUNTS+=(-v "$ADC_FILE:/opt/secrets/gcloud-adc.json:ro")
  ENV_VARS+=(-e "GOOGLE_APPLICATION_CREDENTIALS=/opt/secrets/gcloud-adc.json")

  # Open firewall for BigQuery API
  GCLOUD_DOMAINS="bigquery.googleapis.com,storage.googleapis.com,oauth2.googleapis.com"
  if [ -n "$EXTRA_DOMAINS" ]; then
    EXTRA_DOMAINS="$EXTRA_DOMAINS,$GCLOUD_DOMAINS"
  else
    EXTRA_DOMAINS="$GCLOUD_DOMAINS"
  fi

  # Auto-generate minimal BQ MCP config if none provided
  if [ -z "$BQ_MCP_CONFIG" ] && [ -z "$BQ_MCP_CONFIG_PATH" ]; then
    GCLOUD_BQ_CONFIG=$(mktemp)
    echo '{"auth_mode": "adc"}' > "$GCLOUD_BQ_CONFIG"
    BQ_MCP_CONFIG="$GCLOUD_BQ_CONFIG"
  fi
fi

# ── Snowflake (read-only MCP) ─────────────────────────────────
SNOWFLAKE_ENABLED=false
SNOWFLAKE_VARS=(SNOWFLAKE_ACCOUNT SNOWFLAKE_USER SNOWFLAKE_WAREHOUSE SNOWFLAKE_DATABASE SNOWFLAKE_ROLE)

for var in "${SNOWFLAKE_VARS[@]}"; do
  if [ -n "${!var}" ]; then
    ENV_VARS+=(-e "$var=${!var}")
  fi
done

if [ -n "$SNOWFLAKE_ACCOUNT" ] && [ -n "$SNOWFLAKE_KEY" ]; then
  SNOWFLAKE_ENABLED=true
  SNOWFLAKE_KEY=$(cd "$(dirname "$SNOWFLAKE_KEY")" && pwd)/$(basename "$SNOWFLAKE_KEY")
  if [ ! -f "$SNOWFLAKE_KEY" ]; then
    echo "ERROR: Snowflake key not found: $SNOWFLAKE_KEY"
    exit 1
  fi
  MOUNTS+=(-v "$SNOWFLAKE_KEY:/opt/secrets/snowflake_key.pem:ro")
  ENV_VARS+=(-e "SNOWFLAKE_PRIVATE_KEY_PATH=/opt/secrets/snowflake_key.pem")

  # Add Snowflake domains to firewall allowlist
  SF_DOMAIN="${SNOWFLAKE_ACCOUNT}.snowflakecomputing.com"
  if [ -n "$EXTRA_DOMAINS" ]; then
    EXTRA_DOMAINS="$EXTRA_DOMAINS,$SF_DOMAIN"
  else
    EXTRA_DOMAINS="$SF_DOMAIN"
  fi
fi

# ── Data Detective ────────────────────────────────────────────
# Detective uses claude CLI (inherits OAuth auth) — no separate API key needed.
# Enabled when any data connector credentials are available.
DETECTIVE_ENABLED=false

# Auto-map SNOWFLAKE_* → SF_* for detective (if SF_* not explicitly set)
: "${SF_ACCOUNT:=$SNOWFLAKE_ACCOUNT}"
: "${SF_USER:=$SNOWFLAKE_USER}"
: "${SF_PASSWORD:=$SNOWFLAKE_PASSWORD}"
: "${SF_WAREHOUSE:=$SNOWFLAKE_WAREHOUSE}"
: "${SF_DATABASE:=$SNOWFLAKE_DATABASE}"
: "${SF_ROLE:=$SNOWFLAKE_ROLE}"

if [ -n "$SF_ACCOUNT" ] || [ -n "$BQ_PROJECT" ]; then
  DETECTIVE_ENABLED=true

  # Pass detective tuning vars
  DETECTIVE_TUNE_VARS=(DETECTIVE_MODEL DETECTIVE_MAX_ITER)
  for var in "${DETECTIVE_TUNE_VARS[@]}"; do
    if [ -n "${!var}" ]; then
      ENV_VARS+=(-e "$var=${!var}")
    fi
  done

  # Pass BigQuery vars
  BQ_VARS=(BQ_PROJECT BQ_CREDENTIALS_PATH)
  for var in "${BQ_VARS[@]}"; do
    if [ -n "${!var}" ]; then
      ENV_VARS+=(-e "$var=${!var}")
    fi
  done

  # Pass Snowflake vars (SF_* prefix for detective)
  SF_VARS=(SF_ACCOUNT SF_USER SF_PASSWORD SF_PRIVATE_KEY_PATH SF_WAREHOUSE SF_DATABASE SF_SCHEMA SF_ROLE)
  for var in "${SF_VARS[@]}"; do
    if [ -n "${!var}" ]; then
      ENV_VARS+=(-e "$var=${!var}")
    fi
  done

  # Add BigQuery API domains if BQ is configured
  if [ -n "$BQ_PROJECT" ]; then
    BQ_DOMAINS="bigquery.googleapis.com,storage.googleapis.com,oauth2.googleapis.com"
    if [ -n "$EXTRA_DOMAINS" ]; then
      EXTRA_DOMAINS="$EXTRA_DOMAINS,$BQ_DOMAINS"
    else
      EXTRA_DOMAINS="$BQ_DOMAINS"
    fi
  fi

  # Add Snowflake domain for detective (if not already added by read-only MCP)
  if [ -n "$SF_ACCOUNT" ] && [ "$SNOWFLAKE_ENABLED" != true ]; then
    SF_DOMAIN="${SF_ACCOUNT}.snowflakecomputing.com"
    if [ -n "$EXTRA_DOMAINS" ]; then
      EXTRA_DOMAINS="$EXTRA_DOMAINS,$SF_DOMAIN"
    else
      EXTRA_DOMAINS="$SF_DOMAIN"
    fi
  fi

  # Auto-discover BQ credentials from project if not explicitly provided
  if [ -z "$BQ_CREDENTIALS" ] && [ -n "$BQ_CREDENTIALS_PATH" ]; then
    # If path from .env is relative, resolve against project dir
    if [[ "$BQ_CREDENTIALS_PATH" != /* ]]; then
      candidate="$PROJECT_DIR/$BQ_CREDENTIALS_PATH"
    else
      candidate="$BQ_CREDENTIALS_PATH"
    fi
    [ -f "$candidate" ] && BQ_CREDENTIALS="$candidate"
  fi

  # Auto-discover SF private key from project if path is relative
  if [ -n "$SF_PRIVATE_KEY_PATH" ] && [[ "$SF_PRIVATE_KEY_PATH" != /* ]]; then
    candidate="$PROJECT_DIR/$SF_PRIVATE_KEY_PATH"
    if [ -f "$candidate" ]; then
      SF_PRIVATE_KEY_PATH=$(cd "$(dirname "$candidate")" && pwd)/$(basename "$candidate")
      MOUNTS+=(-v "$SF_PRIVATE_KEY_PATH:/opt/secrets/sf_key.pem:ro")
      ENV_VARS+=(-e "SF_PRIVATE_KEY_PATH=/opt/secrets/sf_key.pem")
    fi
  fi
fi

# ── BigQuery MCP ──────────────────────────────────────────
# Standalone BigQuery MCP server (separate from Data Detective).
# Activated by BQ_MCP_CONFIG (path to JSON config file) or --bq-mcp-config flag.
BQ_MCP_ENABLED=false

# Resolve config file: CLI flag takes precedence over env var
BQ_MCP_CONFIG_RESOLVED="${BQ_MCP_CONFIG:-${BQ_MCP_CONFIG_PATH:-}}"

if [ -n "$BQ_MCP_CONFIG_RESOLVED" ]; then
  # Resolve relative to project dir
  if [[ "$BQ_MCP_CONFIG_RESOLVED" != /* ]]; then
    BQ_MCP_CONFIG_RESOLVED="$PROJECT_DIR/$BQ_MCP_CONFIG_RESOLVED"
  fi
  BQ_MCP_CONFIG_RESOLVED=$(cd "$(dirname "$BQ_MCP_CONFIG_RESOLVED")" && pwd)/$(basename "$BQ_MCP_CONFIG_RESOLVED")
  if [ ! -f "$BQ_MCP_CONFIG_RESOLVED" ]; then
    echo "ERROR: BigQuery MCP config not found: $BQ_MCP_CONFIG_RESOLVED"
    exit 1
  fi
  MOUNTS+=(-v "$BQ_MCP_CONFIG_RESOLVED:/opt/secrets/bq-mcp-config.json:ro")
  ENV_VARS+=(-e "BQ_MCP_CONFIG_PATH=/opt/secrets/bq-mcp-config.json")
  BQ_MCP_ENABLED=true

  # Add BigQuery API domains to firewall allowlist
  BQ_MCP_DOMAINS="bigquery.googleapis.com,storage.googleapis.com,oauth2.googleapis.com"
  if [ -n "$EXTRA_DOMAINS" ]; then
    EXTRA_DOMAINS="$EXTRA_DOMAINS,$BQ_MCP_DOMAINS"
  else
    EXTRA_DOMAINS="$BQ_MCP_DOMAINS"
  fi

  # If service_account mode, also mount the SA key file referenced in the config
  SA_KEY_PATH=$(python3 -c "
import json, sys
try:
  c = json.load(open('$BQ_MCP_CONFIG_RESOLVED'))
  print(c.get('service_account_key_path', ''))
except:
  print('')
" 2>/dev/null || true)

  if [ -n "$SA_KEY_PATH" ] && [ -f "$SA_KEY_PATH" ]; then
    SA_KEY_PATH=$(cd "$(dirname "$SA_KEY_PATH")" && pwd)/$(basename "$SA_KEY_PATH")
    MOUNTS+=(-v "$SA_KEY_PATH:/opt/secrets/bq-sa-key.json:ro")
    echo "  BigQuery SA key: $SA_KEY_PATH → /opt/secrets/bq-sa-key.json"
  elif [ -n "$SA_KEY_PATH" ] && [ ! -f "$SA_KEY_PATH" ]; then
    echo "WARNING: BigQuery SA key referenced in config not found: $SA_KEY_PATH"
  fi
fi

# Mount BigQuery credentials file if provided (explicit or auto-discovered)
if [ -n "$BQ_CREDENTIALS" ]; then
  BQ_CREDENTIALS=$(cd "$(dirname "$BQ_CREDENTIALS")" && pwd)/$(basename "$BQ_CREDENTIALS")
  if [ ! -f "$BQ_CREDENTIALS" ]; then
    echo "ERROR: BigQuery credentials not found: $BQ_CREDENTIALS"
    exit 1
  fi
  MOUNTS+=(-v "$BQ_CREDENTIALS:/opt/secrets/bq-credentials.json:ro")
  ENV_VARS+=(-e "BQ_CREDENTIALS_PATH=/opt/secrets/bq-credentials.json")
fi

# ── Plan env vars ─────────────────────────────────────────────
if [ -n "$PLAN_FILE" ]; then
  ENV_VARS+=(-e "WALTER_PLAN_FILE=$PLAN_FILE_CONTAINER")
  [ -n "$PLAN_MAX_ITERATIONS" ] && ENV_VARS+=(-e "WALTER_MAX_ITERATIONS=$PLAN_MAX_ITERATIONS")
  [ -n "$PLAN_RETRY_COUNT" ] && ENV_VARS+=(-e "WALTER_RETRY_COUNT=$PLAN_RETRY_COUNT")
fi
[ "$REVIEW" = true ] && ENV_VARS+=(-e "WALTER_REVIEW=true")
[ "$REVIEW_ONLY" = true ] && ENV_VARS+=(-e "WALTER_REVIEW_ONLY=true")

# ── Session directory (host-side logging for dashboard) ──────
SESSIONS_DIR="$HOME/.walter/sessions"
SESSION_ID="$(basename "$PROJECT_DIR")-$(date +%s)"
SESSION_DIR="$SESSIONS_DIR/$SESSION_ID"
mkdir -p "$SESSION_DIR" && chmod 777 "$SESSION_DIR"

# Write session metadata
cat > "$SESSION_DIR/session.json" << SESEOF
{
  "id": "$SESSION_ID",
  "project_dir": "$PROJECT_DIR",
  "project_name": "$(basename "$PROJECT_DIR")",
  "started_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "plan_file": "${PLAN_FILE_REL:-}",
  "mode": "$([ -n "$PLAN_FILE" ] && echo "plan" || echo "interactive")"
}
SESEOF

# Mount session dir as /var/log/walter/ inside container
MOUNTS+=(-v "$SESSION_DIR:/var/log/walter")

# Persistent corrections log (survives across sessions)
CORRECTIONS_DIR="$HOME/.walter/corrections"
mkdir -p "$CORRECTIONS_DIR"
MOUNTS+=(-v "$CORRECTIONS_DIR:/var/log/walter/corrections")
ENV_VARS+=(-e "WALTER_PROJECT_NAME=$(basename "$PROJECT_DIR")")

# ── Entrypoint args (network-lock allowlist) ─────────────────
ENTRYPOINT_ARGS=()
[ -n "$EXTRA_DOMAINS" ] && ENTRYPOINT_ARGS+=(--allowlist "$EXTRA_DOMAINS")

# ── Banner ───────────────────────────────────────────────────
echo "══════════════════════════════════════════════════════"
echo "  walter (Docker + Network Lock)"
echo ""
if [ "$REVIEW_ONLY" = true ]; then
echo "  Mode:        REVIEW ONLY"
echo ""
elif [ -n "$PLAN_FILE" ]; then
echo "  Mode:        PLAN EXECUTION$([ "$REVIEW" = true ] && echo " + REVIEW")"
echo "  Plan:        $PLAN_FILE_REL"
echo ""
fi
echo "  Project:     $PROJECT_DIR"
echo "  Auth:        $AUTH_METHOD"
echo ""
echo "  Network:"
echo "     api.anthropic.com, console.anthropic.com, claude.ai"
[ -n "$EXTRA_DOMAINS" ] && echo "     $EXTRA_DOMAINS"
echo "     everything else blocked (IPv4 + IPv6)"
echo ""
echo "  Agents:    $([ -d "$CLAUDE_HOME/agents" ] && echo "mounted from $CLAUDE_HOME/agents" || echo "not found")"
echo "  Commands:  $([ -d "$CLAUDE_HOME/commands" ] && echo "mounted from $CLAUDE_HOME/commands" || echo "not found")"
echo "  Skills:    $([ -d "$CLAUDE_HOME/skills" ] && echo "mounted from $CLAUDE_HOME/skills" || echo "not found")"
echo "  Settings:  $([ -f "$CLAUDE_HOME/settings.json" ] && echo "merged from host" || echo "container defaults")"
echo ""
if [ "$SNOWFLAKE_ENABLED" = true ]; then
echo "  Snowflake:"
echo "     MCP: snowflake-readonly (read-only)"
echo "     Account: $SNOWFLAKE_ACCOUNT"
echo "     Key: $SNOWFLAKE_KEY"
echo ""
fi
if [ "$BQ_MCP_ENABLED" = true ]; then
echo "  BigQuery MCP:"
echo "     MCP: bigquery (read + write to configured dataset)"
echo "     Config: $BQ_MCP_CONFIG_RESOLVED"
echo ""
fi
if [ "$GCLOUD_ADC" = true ]; then
echo "  gcloud ADC:"
echo "     Mounted from host (~/.config/gcloud/)"
echo "     BigQuery API domains allowed through firewall"
echo ""
fi
if [ "$CODEX_ENABLED" = true ]; then
echo "  Peer Review:"
echo "     Codex CLI (OpenAI) — /peer-review command"
[ -f "$CODEX_HOME/auth.json" ] && echo "     Auth: $CODEX_HOME/auth.json"
[ -n "$OPENAI_API_KEY" ] && echo "     Auth: OPENAI_API_KEY"
echo ""
fi
if [ "$DETECTIVE_ENABLED" = true ]; then
echo "  Data Detective:"
echo "     MCP: data-detective (autonomous investigation)"
echo "     Config: $PROJECT_DIR/.env"
[ -n "$BQ_PROJECT" ] && echo "     BigQuery: $BQ_PROJECT"
[ -n "$BQ_CREDENTIALS" ] && echo "     BQ Creds: $BQ_CREDENTIALS"
[ -n "$SF_ACCOUNT" ] && echo "     Snowflake: $SF_ACCOUNT"
echo ""
fi
echo "  Security:"
echo "     iptables + ip6tables firewall"
echo "     credential-guard hooks"
echo "     no-new-privileges"
echo ""
echo "  Session: $SESSION_ID"
echo "     Logs: $SESSION_DIR"
echo "     View: walter dashboard"
echo "══════════════════════════════════════════════════════"
echo ""

# ── Interactive flag ─────────────────────────────────────────
INTERACTIVE_FLAG="-it"
[ -t 0 ] || INTERACTIVE_FLAG="-i"

DOCKER_EXIT=0
docker run --rm $INTERACTIVE_FLAG \
  --name "walter-$SESSION_ID" \
  --cap-add NET_ADMIN \
  "${MOUNTS[@]}" \
  "${ENV_VARS[@]}" \
  --tmpfs /tmp:exec \
  --security-opt no-new-privileges \
  "$IMAGE_NAME:$IMAGE_TAG" \
  "${ENTRYPOINT_ARGS[@]}" \
  "${CLAUDE_ARGS[@]}" || DOCKER_EXIT=$?

# ── Cleanup session directory ────────────────────────────────
rm -rf "$SESSION_DIR"

exit $DOCKER_EXIT
