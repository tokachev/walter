{
  "statusLine": {
    "type": "command",
    "command": "bash /opt/hooks/statusline-command.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/hooks/inject-temporal-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/guardrails/hook.sh",
            "statusMessage": "Guardrails check..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/hooks/credential-guard.sh write",
            "statusMessage": "Scanning for credentials..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/hooks/credential-guard.sh edit",
            "statusMessage": "Scanning for credentials..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/hooks/credential-guard.sh bash",
            "statusMessage": "Scanning for credentials..."
          }
        ]
      }
    ]
  }
}
